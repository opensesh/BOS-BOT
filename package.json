{
  "name": "@opensession/bos-bot",
  "version": "1.0.0",
  "description": "REMY - CRT Tamagotchi-style product avatar for Open Session",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "vite",
    "preview": "vite",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opensesh/BOS-BOT.git"
  },
  "keywords": [
    "react",
    "avatar",
    "crt",
    "tamagotchi",
    "canvas",
    "animation",
    "open-session",
    "bos"
  ],
  "author": "Open Session",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/opensesh/BOS-BOT/issues"
  },
  "homepage": "https://github.com/opensesh/BOS-BOT#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.0"
  }
}
